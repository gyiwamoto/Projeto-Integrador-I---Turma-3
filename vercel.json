{
  "installCommand": "npm install --prefix frontend && npm install --prefix api",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist/dentista-organizado/browser",
  "functions": {
    "api/auth/index.ts": {
      "runtime": "@vercel/node@5.1.4"
    },
    "api/usuarios/index.ts": {
      "runtime": "@vercel/node@5.1.4"
    },
    "api/pacientes/index.ts": {
      "runtime": "@vercel/node@5.1.4"
    },
    "api/convenios/index.ts": {
      "runtime": "@vercel/node@5.1.4"
    },
    "api/consultas/index.ts": {
      "runtime": "@vercel/node@5.1.4"
    },
    "api/tratamentos/index.ts": {
      "runtime": "@vercel/node@5.1.4"
    },
    "api/procedimentos-realizados/index.ts": {
      "runtime": "@vercel/node@5.1.4"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}