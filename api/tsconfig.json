{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "rootDir": "..",
    "outDir": "dist",
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo.api.json"
  },
  "include": ["./**/*.ts", "../services/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
